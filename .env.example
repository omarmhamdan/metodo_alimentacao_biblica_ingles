# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Worker secrets / vars (Hotmart webhook + access email).
# These are NOT bundled in the client. Set them with `wrangler secret put <NAME>`
# or in the Cloudflare dashboard → Worker → Settings → Variables. Never commit
# real values to the repo.
# ─────────────────────────────────────────────────────────────────────────────

# Hotmart webhook verification token (X-HOTMART-HOTTOK header / body.hottok).
HOTMART_HOTTOK=

# Supabase — service role key BYPASSES RLS; Worker-only, never expose to client.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: harden product mapping once you know the numeric Hotmart product IDs.
# JSON map of productId -> upsell key, e.g. {"7909761":"anti-inflamacao"}
HOTMART_PRODUCT_MAP=

# Brevo transactional email API key (sends the Spanish access email).
# Brevo dashboard → SMTP & API → API Keys.
BREVO_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Client (Vite) — safe to expose; these are the public anon values.
# Copy to .env.local for local dev (see .env.local.example).
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=
